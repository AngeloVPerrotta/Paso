---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}
const {
  title = "Paso — Aprendé a programar jugando",
  description = "Paso es un juego de lógica: armás la solución pieza por pieza, un robot la ejecuta, y después lo ves en C y C# de verdad. Incluye un módulo para aprender Git. Jugá gratis en el navegador.",
} = Astro.props;
const ogImage = new URL("/shots/shot_inicio.png", Astro.site ?? "https://paso.angeloperrotta.online").href;
---
<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="theme-color" content="#F5F2EA" />

    <!-- Open Graph (link preview) -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta name="twitter:card" content="summary_large_image" />

    <!-- Fuentes: Fraunces (serif humanista, títulos) + Inter (sans, cuerpo) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,500;9..144,600&family=Inter:wght@400;500;600&display=swap"
    />
  </head>
  <body>
    <slot />

    <script>
      // Scroll-reveal (IntersectionObserver) + parallax leve del robot. Vanilla, sin deps.
      const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

      const items = document.querySelectorAll("[data-reveal]");
      if (reduce || !("IntersectionObserver" in window)) {
        items.forEach((el) => el.classList.add("is-visible"));
      } else {
        const io = new IntersectionObserver(
          (entries) => {
            entries.forEach((e) => {
              if (e.isIntersecting) {
                e.target.classList.add("is-visible");
                io.unobserve(e.target);
              }
            });
          },
          { threshold: 0.12, rootMargin: "0px 0px -8% 0px" }
        );
        items.forEach((el) => io.observe(el));
      }

      // Parallax leve: el robot del hero se mueve más lento que el texto al scrollear.
      if (!reduce) {
        const robot = document.querySelector<HTMLElement>("[data-parallax]");
        if (robot) {
          let ticking = false;
          const update = () => {
            robot.style.setProperty("--parallax", `${window.scrollY * 0.12}px`);
            ticking = false;
          };
          window.addEventListener(
            "scroll",
            () => {
              if (!ticking) {
                ticking = true;
                requestAnimationFrame(update);
              }
            },
            { passive: true }
          );
        }
      }

      // Pet del scroll: el robot se vuelve mascota fija de la esquina al dejar el hero.
      // Se esconde sobre el footer (no tapa los links). Reacciones sutiles, no constantes.
      const pet = document.querySelector<HTMLElement>(".pet");
      if (pet) {
        const hero = document.querySelector(".hero");
        const footer = document.querySelector(".footer");
        let heroVis = true;
        let footVis = false;
        const syncPet = () => pet.classList.toggle("pet--on", !heroVis && !footVis);
        const edges = new IntersectionObserver(
          (entries) => {
            entries.forEach((e) => {
              if (e.target === hero) heroVis = e.isIntersecting;
              if (e.target === footer) footVis = e.isIntersecting;
            });
            syncPet();
          },
          { threshold: 0 }
        );
        if (hero) edges.observe(hero);
        if (footer) edges.observe(footer);

        // Vivo pero sutil: mira hacia la sección activa (leve inclinación alternada) y da un
        // micro-bote al cambiar. Solo si el usuario no pidió menos movimiento.
        if (!reduce) {
          let activa: Element | null = null;
          let flip = false;
          const act = new IntersectionObserver(
            (entries) => {
              entries.forEach((e) => {
                if (e.isIntersecting && e.target !== activa) {
                  activa = e.target;
                  flip = !flip;
                  pet.classList.remove("pet--look-left", "pet--look-right", "pet--bounce");
                  pet.classList.add(flip ? "pet--look-left" : "pet--look-right");
                  void pet.offsetWidth; // reinicia la animación del bote
                  pet.classList.add("pet--bounce");
                }
              });
            },
            { threshold: 0, rootMargin: "-45% 0px -45% 0px" } // sección que cruza el centro del viewport
          );
          document.querySelectorAll("section").forEach((s) => act.observe(s));
        }
      }
    </script>
  </body>
</html>
