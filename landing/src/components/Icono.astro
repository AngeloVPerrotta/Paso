---
// Íconos de línea simples (currentColor) para los 3 bullets de "Qué es".
// name: "apilar" | "robot" | "codigo".
interface Props { name: "apilar" | "robot" | "codigo"; }
const { name } = Astro.props;
---
{name === "apilar" && (
  <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor"
       stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <rect x="4" y="13.5" width="16" height="5" rx="1.5"/>
    <rect x="6" y="8" width="12" height="5" rx="1.5"/>
    <rect x="8" y="2.5" width="8" height="5" rx="1.5"/>
  </svg>
)}
{name === "robot" && (
  <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor"
       stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <line x1="12" y1="2.5" x2="12" y2="5"/>
    <circle cx="12" cy="2" r="0.6" fill="currentColor"/>
    <rect x="5" y="5" width="14" height="11" rx="3.5"/>
    <circle cx="9.5" cy="10.5" r="1.3"/>
    <circle cx="14.5" cy="10.5" r="1.3"/>
    <path d="M8 20h8"/>
    <path d="M12 16v4"/>
  </svg>
)}
{name === "codigo" && (
  <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor"
       stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <polyline points="8 8 4 12 8 16"/>
    <polyline points="16 8 20 12 16 16"/>
    <line x1="13.5" y1="6" x2="10.5" y2="18"/>
  </svg>
)}
