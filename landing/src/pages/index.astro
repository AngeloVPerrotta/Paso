---
import Base from "../layouts/Base.astro";
import Robot from "../components/Robot.astro";
import Boton from "../components/Boton.astro";
import Icono from "../components/Icono.astro";
import GitAnimado from "../components/GitAnimado.astro";

// ╔══════════════════════════════════════════════════════════════════════╗
// ║  ⚙️  COMPLETÁ ESTAS DOS URLS (Angelo)                                  ║
// ║  - URL_JUGAR: ruta del juego web. Por defecto /jugar (ver jugar.astro).║
// ║  - URL_DESCARGA: poné el .exe en public/descargas/paso.exe.            ║
// ╚══════════════════════════════════════════════════════════════════════╝
const URL_JUGAR = "/jugar";
const URL_DESCARGA = "/descargas/paso.exe";

const REPO = "https://github.com/AngeloVPerrotta/Paso";
const PORTFOLIO = "https://angeloperrotta.online";
const year = new Date().getFullYear();

const bullets = [
  { icono: "apilar", titulo: "Armás programas sin escribir código",
    desc: "Arrastrás órdenes simples —agarrá, guardá, sumá, saltá— y las apilás. Cero sintaxis, cero punto y coma." },
  { icono: "robot", titulo: "Un robot ejecuta tu lógica, a la vista",
    desc: "Lo ves correr paso a paso: la mano que agarra, la memoria y las colas de entrada y salida cambiando en vivo." },
  { icono: "codigo", titulo: "Y lo ves en código real",
    desc: "El mismo programa traducido a C y C#, comentado y legible. El puente para dar el salto a programar de verdad." },
] as const;
---

<Base>
  <!-- ── HERO ─────────────────────────────────────────────────────────── -->
  <a class="logo" href="/" aria-label="Paso — inicio">
    <span class="logo__mark"><Robot variant="mark" /></span>
    <span class="logo__word">Paso</span>
  </a>
  <header class="hero">
    <div class="hero__robot" data-parallax>
      <Robot />
    </div>
    <div class="hero__texto">
      <p class="eyebrow hero__kicker">Juego de lógica · C y C#</p>
      <h1>Paso</h1>
      <p class="hero__tagline">Aprendé a programar jugando: armás la solución pieza por pieza y un robot la ejecuta.</p>
      <div class="cta-fila">
        <Boton href={URL_JUGAR} variant="primary" label="▶  Jugar en el navegador" />
        <Boton href={URL_DESCARGA} variant="secondary" label="⬇  Descargar para Windows" />
      </div>
      <p class="cta-micro">Gratis y sin registro · probás en el navegador, sin instalar nada.</p>
    </div>
  </header>

  <!-- ── QUÉ ES ───────────────────────────────────────────────────────── -->
  <section class="centro" data-reveal>
    <div class="container">
      <p class="eyebrow">Qué es</p>
      <h2 class="lede" style="max-width: 24ch; margin-inline:auto; font-family: var(--serif); font-size: clamp(1.6rem, 4vw, 2.4rem);">
        Aprendés a pensar como un programa —sin escribir código— y después lo ves en C y C# de verdad.
      </h2>
      <ul class="bullets">
        {bullets.map((b) => (
          <li class="bullet">
            <div class="bullet__icono"><Icono name={b.icono} /></div>
            <h3>{b.titulo}</h3>
            <p>{b.desc}</p>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- ── CAPTURAS ─────────────────────────────────────────────────────── -->
  <section data-reveal>
    <div class="container">
      <header class="bloque-head">
        <p class="eyebrow">Un vistazo</p>
        <h2>Así se ve por dentro</h2>
      </header>
      <div class="grid-capturas">
        <figure class="shot">
          <img src="/shots/shot_inicio.png" width="1000" height="900" loading="lazy" decoding="async"
               alt="Pantalla de inicio de Paso: el robot, el título y los botones para empezar." />
          <figcaption>La cara del juego: elegís track (C o C#) y arrancás.</figcaption>
        </figure>
        <figure class="shot">
          <img src="/shots/shot_como.png" width="1000" height="900" loading="lazy" decoding="async"
               alt="La mecánica: entradas, la mano que sostiene un valor, la memoria y las salidas." />
          <figcaption>La máquina: entradas, la “mano”, la memoria y las salidas.</figcaption>
        </figure>
      </div>
    </div>
  </section>

  <!-- ── GIT (sección destacada, animada) ─────────────────────────────── -->
  <GitAnimado />

  <!-- ── CTA FINAL ────────────────────────────────────────────────────── -->
  <section class="centro" data-reveal>
    <div class="container">
      <h2>Probá un nivel ahora. Se juega en el navegador, gratis.</h2>
      <div class="cta-fila">
        <Boton href={URL_JUGAR} variant="primary" label="▶  Jugar en el navegador" />
        <Boton href={URL_DESCARGA} variant="secondary" label="⬇  Descargar para Windows" />
      </div>
    </div>
  </section>

  <!-- ── FOOTER ───────────────────────────────────────────────────────── -->
  <footer class="footer">
    <div class="container">
      <span>Hecho por <a href={PORTFOLIO}>Angelo Perrotta</a> · {year}</span>
      <nav class="footer__links">
        <a href={REPO}>GitHub del repo</a>
        <a href={PORTFOLIO}>Portfolio</a>
      </nav>
    </div>
  </footer>

  <!-- Pet del scroll: al dejar el hero, el robot aparece achicado en la esquina y te
       acompaña. Capas separadas: .pet (posición/aparición) · .pet__bob (rebote) ·
       .pet__tilt (mira hacia la sección). Decorativo (aria-hidden, no captura clics). -->
  <div class="pet" aria-hidden="true">
    <div class="pet__bob">
      <div class="pet__tilt"><Robot variant="pet" /></div>
    </div>
  </div>
</Base>
